# === StaLLM LLM slots (.env.example) ===
# List available slots and choose a default
STALLM_SLOTS=AZ1,OA1,OL1
STALLM_DEFAULT_SLOT=AZ1

# ----- Azure OpenAI slot -----
AZ1_PROVIDER=azure-openai
AZ1_LABEL=Azure gpt-4o
AZ1_API_BASE=https://YOUR_RESOURCE.openai.azure.com/
AZ1_API_VERSION=2024-05-01-preview
AZ1_API_KEY=__SET_ME__
AZ1_DEPLOYMENT=YOUR_DEPLOYMENT_NAME

# Optional: slot-specific pricing for cost estimates (USD per 1K tokens)
AZ1_PRICE_IN_PER_1K=2.50
AZ1_PRICE_OUT_PER_1K=10.00

# ----- OpenAI slot -----
OA1_PROVIDER=openai
OA1_LABEL=OpenAI gpt-4o-mini
OA1_API_KEY=__SET_ME__
OA1_MODEL=gpt-4o-mini

# ----- Ollama (local) slot -----
OL1_PROVIDER=ollama
OL1_LABEL=Ollama llama3
OL1_HOST=http://localhost:11434
OL1_MODEL=llama3

# ----- Global pricing fallback (optional) -----
STALLM_PRICE_IN_PER_1K=2.50
STALLM_PRICE_OUT_PER_1K=10.00
