# === StaLLM LLM slots (.env.example) ===
# List available slots and choose a default
STALLM_SLOTS=AZ1,OA1,OL1,OL2,OL3,OL4,OL5,OL6,OL7
STALLM_DEFAULT_SLOT=OL1

# ----- Azure OpenAI slot -----
AZ1_PROVIDER=azure-openai
AZ1_LABEL=Azure gpt-4o
AZ1_API_BASE=https://YOUR_RESOURCE.openai.azure.com/
AZ1_API_VERSION=2024-05-01-preview
AZ1_API_KEY=__SET_ME__
AZ1_DEPLOYMENT=YOUR_DEPLOYMENT_NAME

# Optional: slot-specific pricing for cost estimates (USD per 1K tokens)
AZ1_PRICE_IN_PER_1K=2.50
AZ1_PRICE_OUT_PER_1K=10.00

# ----- OpenAI slot -----
OA1_PROVIDER=openai
OA1_LABEL=OpenAI gpt-4o-mini
OA1_API_KEY=__SET_ME__
OA1_MODEL=gpt-4o-mini

# ----- Ollama (GPT-OSS 20B) - Large model for complex analysis -----
OL1_PROVIDER=ollama
OL1_LABEL=GPT-OSS 20B (Large)
OL1_HOST=http://localhost:11434
OL1_MODEL=gpt-oss:20b

# ----- Ollama (Gemma3 1B) - Fast, lightweight model -----
OL2_PROVIDER=ollama
OL2_LABEL=Gemma3 1B (Fast)
OL2_HOST=http://localhost:11434
OL2_MODEL=gemma3:1b

# ----- Ollama (Phi3 Mini) - Balanced performance -----
OL3_PROVIDER=ollama
OL3_LABEL=Phi3 Mini (Balanced)
OL3_HOST=http://localhost:11434
OL3_MODEL=phi3:mini

# ----- Ollama (DeepSeek R1 14B) - Reasoning model -----
OL4_PROVIDER=ollama
OL4_LABEL=DeepSeek R1 14B (Reasoning)
OL4_HOST=http://localhost:11434
OL4_MODEL=deepseek-r1:14b

# ----- Ollama (DeepSeek Coder V2) - Code specialist -----
OL5_PROVIDER=ollama
OL5_LABEL=DeepSeek Coder V2 (Code)
OL5_HOST=http://localhost:11434
OL5_MODEL=deepseek-coder-v2:latest

# ----- Ollama (Llama2) - Classic model -----
OL6_PROVIDER=ollama
OL6_LABEL=Llama2 Latest (Classic)
OL6_HOST=http://localhost:11434
OL6_MODEL=llama2:latest

# ----- Ollama (Mistral) - Alternative model -----
OL7_PROVIDER=ollama
OL7_LABEL=Mistral Latest (Alternative)
OL7_HOST=http://localhost:11434
OL7_MODEL=mistral:latest

# ----- Global pricing fallback (optional) -----
STALLM_PRICE_IN_PER_1K=2.50
STALLM_PRICE_OUT_PER_1K=10.00

# ----- Ollama-specific configuration -----
# Default models to show in UI when host connectivity fails
STALLM_MODELS_OLLAMA=gpt-oss:20b,gemma3:1b,phi3:mini,deepseek-r1:14b,deepseek-coder-v2:latest,llama2:latest,mistral:latest

# Connection timeout for Ollama hosts (seconds)
STALLM_OLLAMA_TIMEOUT=10
